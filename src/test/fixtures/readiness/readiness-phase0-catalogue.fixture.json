  "stateFixtures": [
    {
      "id": "state-available",
      "state": "Available",
      "qualifyingEvidenceSupplied": true,
      "semanticInvariant": "Qualifying evidence is supplied with sufficient provenance and satisfies every applicable explicit freshness rule."
    },
    {
      "id": "state-partial",
      "state": "Partial",
      "qualifyingEvidenceSupplied": true,
      "semanticInvariant": "Some qualifying evidence exists, but expected records, fields, intervals or scope are incomplete; Partial is not Missing."
    },
    {
      "id": "state-permission-limited",
      "state": "PermissionLimited",
      "qualifyingEvidenceSupplied": false,
      "semanticInvariant": "Consultation was attempted and access constraints prevented complete retrieval; this is not proof that evidence or an event does not exist."
    },
    {
      "id": "state-missing",
      "state": "Missing",
      "qualifyingEvidenceSupplied": false,
      "semanticInvariant": "The profile expects the contributor and consultation was possible, but no qualifying evidence was supplied; this is not negative evidence."
    },
    {
      "id": "state-not-consulted",
      "state": "NotConsulted",
      "qualifyingEvidenceSupplied": false,
      "semanticInvariant": "The contributor was not requested, loaded or evaluated; NotConsulted is not Missing."
    },
    {
      "id": "state-unsupported",
      "state": "Unsupported",
      "qualifyingEvidenceSupplied": false,
      "semanticInvariant": "The current input kind, provider version, environment or product capability does not support the contributor; this is not a runtime failure."
    },
    {
      "id": "state-stale",
      "state": "Stale",
      "qualifyingEvidenceSupplied": true,
      "semanticInvariant": "Evidence exists but fails an explicit provider-owned or profile-owned freshness rule relative to assessmentUtc; it remains inspectable but is not current evidence."
    }
  ],
