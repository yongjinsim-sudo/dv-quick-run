        { "id": "metadata.evidence", "role": "Recommended", "appliesWhen": "metadata-or-schema-findings-relevant", "absenceBehavior": "A material limitation is Medium." },
        { "id": "configuration.evidence", "role": "Recommended", "appliesWhen": "configuration-or-runtime-findings-relevant", "absenceBehavior": "A material limitation is Medium." },
        { "id": "identity.evidence", "role": "Recommended", "appliesWhen": "identity-ownership-or-participation-findings-relevant", "absenceBehavior": "A material limitation is Medium." },
        { "id": "audit.evidence", "role": "Recommended", "appliesWhen": "audit-requested-or-actor-change-time-intent", "absenceBehavior": "A limitation is Medium by default." },
        { "id": "timeline.evidence", "role": "Recommended", "appliesWhen": "temporal-progression-or-change-interval-requested", "absenceBehavior": "A material limitation is Medium." },
        { "id": "query.evidence", "role": "Optional", "appliesWhen": "runtime-or-query-confirmation-attached", "absenceBehavior": "Absence alone produces no gap." }
