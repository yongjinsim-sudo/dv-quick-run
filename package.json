{
  "name": "dv-quick-run",
  "displayName": "DV Quick Run",
  "description": "Metadata-aware Dataverse query, investigation, execution, comparison, and operational timeline reconstruction workbench for OData, FetchXML, and $batch in VS Code.",
  "version": "0.13.2",
  "publisher": "dv-forgelab",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongjinsim-sudo/dv-quick-run"
  },
  "homepage": "https://www.dvquickrun.com/",
  "bugs": {
    "url": "https://github.com/yongjinsim-sudo/dv-quick-run/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "license": "MIT",
  "categories": [
    "Other",
    "Debuggers",
    "Testing"
  ],
  "extensionKind": [
    "workspace"
  ],
  "keywords": [
    "dataverse",
    "dataverse api",
    "dataverse query",
    "dataverse odata",
    "dynamics",
    "dynamics365",
    "dynamics api",
    "powerplatform",
    "power platform",
    "power platform dataverse",
    "crm",
    "odata",
    "fetchxml",
    "vscode dataverse",
    "dataverse developer",
    "dataverse tooling",
    "dataverse batch",
    "odata batch",
    "query workflow",
    "dataverse tooling vscode",
    "bulk upsert",
    "dataverse bulk upsert",
    "dataverse migration",
    "dataverse import",
    "dataverse export",
    "dataverse investigation",
    "dataverse comparison",
    "dataverse diff",
    "dataverse snapshot",
    "dataverse operational investigation",
    "dataverse timeline",
    "dataverse timeline reconstruction",
    "dataverse investigation report",
    "dataverse evidence workspace",
    "dataverse snapshot timeline",
    "dataverse drift investigation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:dvQuickRun.openSnapshotLibrary",
    "onCommand:dvQuickRun.createEvidenceWorkspace",
    "onCommand:dvQuickRun.activateProLicense",
    "onCommand:dvQuickRun.licenseStatus",
    "onCommand:dvQuickRun.deactivateProLicense",
    "onCommand:dvQuickRun.importOfflineLicense",
    "onCommand:dvQuickRun.showWelcomeScreen"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dvQuickRun.whoAmI",
        "title": "DV Quick Run: Who Am I"
      },
      {
        "command": "dvQuickRun.runGet",
        "title": "DV Quick Run: Run Query"
      },
      {
        "command": "dvQuickRun.clearHistory",
        "title": "DV Quick Run: Clear Query History"
      },
      {
        "command": "dvQuickRun.getMetadata",
        "title": "DV Quick Run: Get Metadata"
      },
      {
        "command": "dvQuickRun.showEntityMetadata",
        "title": "DV Quick Run: Show Entity Metadata"
      },
      {
        "command": "dvQuickRun.smartGet",
        "title": "DV Quick Run: Build Smart GET"
      },
      {
        "command": "dvQuickRun.smartGetRerunLast",
        "title": "DV Quick Run: Smart GET (Re-run Last)"
      },
      {
        "command": "dvQuickRun.smartGetEditLast",
        "title": "DV Quick Run: Smart GET (Edit Last)"
      },
      {
        "command": "dvQuickRun.smartGetFromGuidPickFields",
        "title": "DV Quick Run: Build Smart GET from GUID (Pick Fields)"
      },
      {
        "command": "dvQuickRun.smartGetFromGuidRaw",
        "title": "DV Quick Run: Build Smart GET from GUID"
      },
      {
        "command": "dvQuickRun.smartPatch",
        "title": "DV Quick Run: Build Smart PATCH"
      },
      {
        "command": "dvQuickRun.smartPatchRerunLast",
        "title": "DV Quick Run: Smart PATCH (Re-run Last)"
      },
      {
        "command": "dvQuickRun.smartPatchEditLast",
        "title": "DV Quick Run: Smart PATCH (Edit Last)"
      },
      {
        "command": "dvQuickRun.generateQueryFromJson",
        "title": "DV Quick Run: Generate Query from JSON"
      },
      {
        "command": "dvQuickRun.runQueryUnderCursor",
        "title": "DV Quick Run: Run Query Under Cursor"
      },
      {
        "command": "dvQuickRun.addFieldsSelect",
        "title": "DV Quick Run: Add Select Fields"
      },
      {
        "command": "dvQuickRun.addFilter",
        "title": "DV Quick Run: Add Filter"
      },
      {
        "command": "dvQuickRun.addExpand",
        "title": "DV Quick Run: Add Expand"
      },
      {
        "command": "dvQuickRun.addOrderBy",
        "title": "DV Quick Run: Add Order By"
      },
      {
        "command": "dvQuickRun.explainQuery",
        "title": "DV Quick Run: Explain Query"
      },
      {
        "command": "dvQuickRun.runQueryAtLine",
        "title": "DV Quick Run: Run Query At Line"
      },
      {
        "command": "dvQuickRun.explainQueryAtLine",
        "title": "DV Quick Run: Explain Query At Line"
      },
      {
        "command": "dvQuickRun.relationshipExplorer",
        "title": "DV Quick Run: Explore Relationships"
      },
      {
        "command": "dvQuickRun.findPathToTable",
        "title": "DV Quick Run: Guided Traversal"
      },
      {
        "command": "dvQuickRun.relationshipGraphView",
        "title": "DV Quick Run: View Relationship Graph"
      },
      {
        "command": "dvQuickRun.showMetadataDiagnostics",
        "title": "DV Quick Run: Show Metadata Diagnostics"
      },
      {
        "command": "dvQuickRun.clearMetadataSessionCache",
        "title": "DV Quick Run: Clear Metadata Session Cache"
      },
      {
        "command": "dvQuickRun.clearPersistedMetadataCache",
        "title": "DV Quick Run: Clear Persisted Metadata Cache"
      },
      {
        "command": "dvQuickRun.clearTraversalCache",
        "title": "DV Quick Run: Clear Traversal Cache"
      },
      {
        "command": "dvQuickRun.selectEnvironment",
        "title": "DV Quick Run: Select Environment"
      },
      {
        "command": "dvQuickRun.addEnvironment",
        "title": "DV Quick Run: Add Environment"
      },
      {
        "command": "dvQuickRun.removeEnvironment",
        "title": "DV Quick Run: Remove Environment"
      },
      {
        "command": "dvQuickRun.investigateRecord",
        "title": "DV Quick Run: Investigate Record"
      },
      {
        "command": "dvQuickRun.investigateAccessContext",
        "title": "DV Quick Run: Investigate Access Context"
      },
      {
        "command": "dvQuickRun.trySampleQuery",
        "title": "DV Quick Run: Try Sample Query"
      },
      {
        "command": "dvQuickRun.tryFetchXmlSample",
        "title": "DV Quick Run: Try FetchXML Query"
      },
      {
        "command": "dvQuickRun.openQuickStart",
        "title": "DV Quick Run: Open Quickstart"
      },
      {
        "command": "dvQuickRun.openHub",
        "title": "DV Quick Run: Open Hub"
      },
      {
        "command": "dvQuickRun.discoverCustomApis",
        "title": "DV Quick Run: Discover Custom APIs"
      },
      {
        "command": "dvQuickRun.exportOperationalProfileSnapshot",
        "title": "DV Quick Run: Export Operational Profile Snapshot"
      },
      {
        "command": "dvQuickRun.captureOperationalProfileSnapshot",
        "title": "DV Quick Run: Capture Operational Profile Snapshot"
      },
      {
        "command": "dvQuickRun.openSnapshotLibrary",
        "title": "DV Quick Run: Open Snapshot Library"
      },
      {
        "command": "dvQuickRun.createEvidenceWorkspace",
        "title": "DV Quick Run: Create Evidence Workspace"
      },
      {
        "command": "dvQuickRun.runBatchQueries",
        "title": "DV Quick Run: Run Queries as $batch"
      },
      {
        "command": "dvQuickRun.activateProLicense",
        "title": "DV Quick Run: Activate Pro License"
      },
      {
        "command": "dvQuickRun.licenseStatus",
        "title": "DV Quick Run: License Status"
      },
      {
        "command": "dvQuickRun.deactivateProLicense",
        "title": "DV Quick Run: Deactivate Pro License"
      },
      {
        "command": "dvQuickRun.importOfflineLicense",
        "title": "DV Quick Run: Import Offline License"
      },
      {
        "command": "dvQuickRun.showWelcomeScreen",
        "title": "DV Quick Run: Show Welcome Screen"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dvQuickRun.runQueryAtLine",
          "when": "false"
        },
        {
          "command": "dvQuickRun.explainQueryAtLine",
          "when": "false"
        },
        {
          "command": "dvQuickRun.smartGetRerunLast",
          "when": "false"
        },
        {
          "command": "dvQuickRun.smartGetEditLast",
          "when": "false"
        },
        {
          "command": "dvQuickRun.smartPatchRerunLast",
          "when": "false"
        },
        {
          "command": "dvQuickRun.smartPatchEditLast",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "dvQuickRun.investigateRecord",
          "group": "dvQuickRun_diagnostics@10",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "dvQuickRun.runQueryUnderCursor",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@20"
        },
        {
          "command": "dvQuickRun.explainQuery",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@21"
        },
        {
          "command": "dvQuickRun.findPathToTable",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@23"
        },
        {
          "command": "dvQuickRun.addFieldsSelect",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@31"
        },
        {
          "command": "dvQuickRun.addFilter",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@32"
        },
        {
          "command": "dvQuickRun.addExpand",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@33"
        },
        {
          "command": "dvQuickRun.addOrderBy",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@34"
        },
        {
          "command": "dvQuickRun.smartGetFromGuidRaw",
          "when": "editorHasSelection",
          "group": "dvQuickRun_guid@1"
        },
        {
          "command": "dvQuickRun.smartGetFromGuidPickFields",
          "when": "editorHasSelection",
          "group": "dvQuickRun_guid@2"
        },
        {
          "command": "dvQuickRun.generateQueryFromJson",
          "when": "editorTextFocus && !editorReadonly && editorLangId == json",
          "group": "dvQuickRun_json@1"
        },
        {
          "command": "dvQuickRun.runBatchQueries",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@22"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dvQuickRun.runQueryUnderCursor",
        "key": "ctrl+enter",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "dvQuickRun.runQueryUnderCursor",
        "key": "ctrl+shift+r",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "configuration": {
      "title": "DV Quick Run",
      "properties": {
        "dvQuickRun.productPlan": {
          "type": "string",
          "default": "free",
          "enum": [
            "free"
          ],
          "description": "Legacy configuration fallback. DV Quick Run capability acceleration is resolved from signed/online entitlement state; unknown or unavailable entitlement states degrade to Free."
        },
        "dvQuickRun.environments": {
          "type": "array",
          "description": "List of Dataverse environments available to DV Quick Run.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment name"
              },
              "url": {
                "type": "string",
                "description": "Dataverse base URL (e.g. https://org.crm.dynamics.com)"
              },
              "statusBarColor": {
                "type": "string",
                "enum": [
                  "white",
                  "amber",
                  "red"
                ],
                "default": "white",
                "description": "Status bar color hint for this environment."
              }
            }
          },
          "default": []
        },
        "dvQuickRun.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline CodeLens actions for likely Dataverse query lines."
        },
        "dvQuickRun.enableInlineMetadataHover": {
          "type": "boolean",
          "default": true,
          "description": "Show inline metadata hover for Dataverse query entities, clauses, operators, and fields."
        },
        "dvQuickRun.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "description": "Controls DV Quick Run logging verbosity."
        },
        "dvQuickRun.traversal.allowedTables": {
          "type": "array",
          "default": [
            "account",
            "contact",
            "lead",
            "opportunity",
            "incident",
            "task",
            "appointment",
            "email",
            "phonecall",
            "systemuser",
            "team"
          ],
          "items": {
            "type": "string"
          },
          "description": "Optional allow-list for Guided Traversal.  When populated, traversal only expands through these tables, while always still allowing the selected source and target tables."
        },
        "dvQuickRun.traversal.excludedTables": {
          "type": "array",
          "default": [
            "activitypointer",
            "connection",
            "duplicaterecord",
            "postfollow",
            "postregarding",
            "postrole",
            "principalobjectattributeaccess",
            "processsession",
            "syncerror",
            "slakpinstance",
            "sharepointdocumentlocation"
          ],
          "items": {
            "type": "string"
          },
          "description": "Optional block-list for Guided Traversal.  Excluded tables are skipped during expansion, except when they are the selected source or target table."
        },
        "dvQuickRun.traversal.explainVerbosity": {
          "type": "string",
          "default": "verbose",
          "enum": [
            "off",
            "minimal",
            "verbose"
          ],
          "description": "Controls how much traversal explanation is shown during Guided Traversal."
        },
        "dvQuickRun.investigate.searchScopeTables": {
          "type": "array",
          "default": [
            "account",
            "contact"
          ],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Bounded table patterns used by Investigate Record for weak-context identifier search. Supports wildcards such as `msemr_*`."
        },
        "dvQuickRun.investigate.maxSearchTables": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "markdownDescription": "Maximum number of tables Investigate Record may search during weak-context identifier resolution."
        },
        "dvQuickRun.investigate.maxSearchColumns": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "markdownDescription": "Maximum number of candidate identifier-like columns Investigate Record may evaluate during weak-context identifier resolution."
        },
        "dvQuickRun.execution.aiPolicy": {
          "type": "string",
          "default": "deny",
          "enum": [
            "deny",
            "allow"
          ],
          "description": "Controls execution of AI-related Custom APIs discovered by Capability Explorer. Default deny keeps AI-related operations preview-only unless explicitly allowed."
        },
        "dvQuickRun.snapshotWorkspaceFolder": {
          "type": "string",
          "default": "",
          "description": "Optional workspace-relative or absolute folder for DVQR workspace-backed snapshots. Empty uses .dvqr/snapshots in the current VS Code workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "copy-fixtures": "xcopy src\\test\\fixtures out\\test\\fixtures /E /I /Y"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/pdfkit": "^0.17.6",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "pdfkit": "^0.18.0"
  },
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  }
}
