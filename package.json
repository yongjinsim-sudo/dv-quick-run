{
  "name": "dv-quick-run",
  "displayName": "DV Quick Run",
  "description": "Run, inspect, and investigate Dataverse Web API queries directly inside VS Code. Includes an interactive result viewer, smart query builders, query explanation, record investigation from GUIDs, metadata intelligence, and relationship exploration.",
  "version": "0.5.2",
  "publisher": "dv-forgelab",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongjinsim-sudo/dv-quick-run"
  },
  "homepage": "https://github.com/yongjinsim-sudo/dv-quick-run",
  "bugs": {
    "url": "https://github.com/yongjinsim-sudo/dv-quick-run/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "license": "MIT",
  "categories": [
    "Other",
    "Debuggers",
    "Data Science",
    "Testing"
  ],
  "extensionKind": [
    "workspace"
  ],
  "keywords": [
    "dataverse",
    "dataverse api",
    "dataverse query",
    "dataverse odata",
    "dynamics",
    "dynamics365",
    "dynamics api",
    "powerplatform",
    "power platform",
    "power platform dataverse",
    "crm",
    "odata",
    "fetchxml",
    "vscode dataverse",
    "dataverse developer",
    "dataverse tooling"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "dvQuickRun.whoAmI", "title": "DV Quick Run: Who Am I" },
      { "command": "dvQuickRun.runGet", "title": "DV Quick Run: Run Query" },
      { "command": "dvQuickRun.clearHistory", "title": "DV Quick Run: Clear Query History" },
      { "command": "dvQuickRun.getMetadata", "title": "DV Quick Run: Get Metadata" },
      { "command": "dvQuickRun.showEntityMetadata", "title": "DV Quick Run: Show Entity Metadata"},
      { "command": "dvQuickRun.smartGet", "title": "DV Quick Run: Build Smart GET" },
      { "command": "dvQuickRun.smartGetRerunLast", "title": "DV Quick Run: Smart GET (Re-run Last)" },
      { "command": "dvQuickRun.smartGetEditLast", "title": "DV Quick Run: Smart GET (Edit Last)" },
      { "command": "dvQuickRun.smartGetFromGuidPickFields", "title": "DV Quick Run: Build Smart GET from GUID (Pick Fields)" },
      { "command": "dvQuickRun.smartGetFromGuidRaw", "title": "DV Quick Run: Build Smart GET from GUID" },
      { "command": "dvQuickRun.smartPatch", "title": "DV Quick Run: Build Smart PATCH" },
      { "command": "dvQuickRun.smartPatchRerunLast", "title": "DV Quick Run: Smart PATCH (Re-run Last)" },
      { "command": "dvQuickRun.smartPatchEditLast", "title": "DV Quick Run: Smart PATCH (Edit Last)" },
      { "command": "dvQuickRun.generateQueryFromJson", "title": "DV Quick Run: Generate Query from JSON" },
      { "command": "dvQuickRun.runQueryUnderCursor", "title": "DV Quick Run: Run Query Under Cursor" },
      { "command": "dvQuickRun.addFieldsSelect", "title": "DV Quick Run: Add Select Fields" },
      { "command": "dvQuickRun.addFilter", "title": "DV Quick Run: Add Filter" },
      { "command": "dvQuickRun.addExpand", "title": "DV Quick Run: Add Expand" },
      { "command": "dvQuickRun.addOrderBy", "title": "DV Quick Run: Add Order By" },
      { "command": "dvQuickRun.explainQuery", "title": "DV Quick Run: Explain Query" },
      { "command": "dvQuickRun.runQueryAtLine", "title": "DV Quick Run: Run Query At Line" },
      { "command": "dvQuickRun.explainQueryAtLine", "title": "DV Quick Run: Explain Query At Line" },
      { "command": "dvQuickRun.relationshipExplorer", "title": "DV Quick Run: Explore Relationships" },
      { "command": "dvQuickRun.relationshipGraphView", "title": "DV Quick Run: View Relationship Graph" },
      { "command": "dvQuickRun.showMetadataDiagnostics", "title": "DV Quick Run: Show Metadata Diagnostics" },
      { "command": "dvQuickRun.clearMetadataSessionCache", "title": "DV Quick Run: Clear Metadata Session Cache" },
      { "command": "dvQuickRun.clearPersistedMetadataCache", "title": "DV Quick Run: Clear Persisted Metadata Cache" },
      { "command": "dvQuickRun.selectEnvironment", "title": "DV Quick Run: Select Environment" },
      { "command": "dvQuickRun.addEnvironment", "title": "DV Quick Run: Add Environment" },
      { "command": "dvQuickRun.removeEnvironment", "title": "DV Quick Run: Remove Environment" },
      { "command": "dvQuickRun.investigateRecord", "title": "DV Quick Run: Investigate Record", "category": "DV Quick Run" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "dvQuickRun.runQueryAtLine", "when": "false" },
        { "command": "dvQuickRun.explainQueryAtLine", "when": "false" },
        { "command": "dvQuickRun.smartGetRerunLast", "when": "false" },
        { "command": "dvQuickRun.smartGetEditLast", "when": "false" },
        { "command": "dvQuickRun.smartPatchRerunLast", "when": "false" },
        { "command": "dvQuickRun.smartPatchEditLast", "when": "false" }
      ],
      "editor/context": [
        {
          "command": "dvQuickRun.investigateRecord",
          "group": "dvQuickRun_diagnostics@10",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "dvQuickRun.runQueryUnderCursor",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@20"
        },
        {
          "command": "dvQuickRun.explainQuery",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_diagnostics@21"
        },
        {
          "command": "dvQuickRun.addFieldsSelect",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@31"
        },
        {
          "command": "dvQuickRun.addFilter",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@32"
        },
        {
          "command": "dvQuickRun.addExpand",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@33"
        },
        {
          "command": "dvQuickRun.addOrderBy",
          "when": "editorTextFocus && !editorReadonly",
          "group": "dvQuickRun_queryBuilder@34"
        },
        {
          "command": "dvQuickRun.smartGetFromGuidRaw",
          "when": "editorHasSelection",
          "group": "dvQuickRun_guid@1"
        },
        {
          "command": "dvQuickRun.smartGetFromGuidPickFields",
          "when": "editorHasSelection",
          "group": "dvQuickRun_guid@2"
        },
        {
          "command": "dvQuickRun.generateQueryFromJson",
          "when": "editorTextFocus && !editorReadonly && editorLangId == json",
          "group": "dvQuickRun_json@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dvQuickRun.runQueryUnderCursor",
        "key": "ctrl+enter",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "dvQuickRun.runQueryUnderCursor",
        "key": "ctrl+shift+r",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "configuration": {
      "title": "DV Quick Run",
        "properties": {
          "dvQuickRun.environments": {
          "type": "array",
          "description": "List of Dataverse environments available to DV Quick Run.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment name"
              },
              "url": {
                "type": "string",
                "description": "Dataverse base URL (e.g. https://org.crm.dynamics.com)"
              },
              "statusBarColor": {
              "type": "string",
              "enum": ["white", "amber", "red"],
              "default": "white",
              "description": "Status bar color hint for this environment."
              }
            }
          },
          "default": []
        },
        "dvQuickRun.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline CodeLens actions for likely Dataverse query lines."
        },
        "dvQuickRun.enableInlineMetadataHover": {
          "type": "boolean",
          "default": true,
          "description": "Show inline metadata hover for Dataverse query entities, clauses, operators, and fields."
        },
        "dvQuickRun.logLevel": {
        "type": "string",
        "default": "info",
        "enum": ["error", "warn", "info", "debug"],
        "description": "Controls DV Quick Run logging verbosity."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}