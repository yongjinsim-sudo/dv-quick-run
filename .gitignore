# Proprietary/open-core implementation boundaries.
# The public core repository must not commit paid acceleration modules.
/src/pro/**
!/src/pro/
!/src/pro/.gitkeep
/src/team/**
!/src/team/
!/src/team/.gitkeep
/src/enterprise/**
!/src/enterprise/
!/src/enterprise/.gitkeep


/src/internal/**
!/src/internal/
!/src/internal/.gitkeep

# DVQR internal license generator: keep local/private artifacts out of git.
/tools/license-generator/**
/tools/license-generator/keys/*.pem
/tools/license-generator/output/**
!/tools/license-generator/output/.gitkeep
!/tools/license-generator/keys/.gitkeep
# Local environment / build artifacts
.env
.env.*
*.tsbuildinfo
.next/
next.config.js.map
# Local/license safety fallback
*.dvqr-license.json
*.pem
*.key
*.secret
